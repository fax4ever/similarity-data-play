@prefix rr:   <http://www.w3.org/ns/r2rml#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix :     <http://example.org/enterprise#> .

# ===========================================================================
# MpE — Person
# ===========================================================================

<#MPerson> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TPerson" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{id}" ;
        rr:class :Person
    ] ;
    rr:predicateObjectMap [
        rr:predicate :personName ;
        rr:objectMap [ rr:column "personName" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :surname ;
        rr:objectMap [ rr:column "surname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :dayOfBirth ;
        rr:objectMap [ rr:column "dayOfBirth" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :phone ;
        rr:objectMap [ rr:column "phone" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :email ;
        rr:objectMap [ rr:column "email" ; rr:datatype xsd:string ]
    ] .

# ===========================================================================
# MpHa — Employee (own PK employeeId; IRI uses person_id FK)
# ===========================================================================

<#MEmployee> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TEmployee" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{person_id}" ;
        rr:class :Employee
    ] ;
    rr:predicateObjectMap [
        rr:predicate :employeeId ;
        rr:objectMap [ rr:column "employeeId" ; rr:datatype xsd:integer ]
    ] .

# ===========================================================================
# MpR11m — EmployeeInfo (same TEmployee table, different key)
# ===========================================================================

<#MEmployeeInfo> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TEmployee" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#empinfo/{info_id}" ;
        rr:class :EmployeeInfo
    ] ;
    rr:predicateObjectMap [
        rr:predicate :address ;
        rr:objectMap [ rr:column "address" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :citizenStatus ;
        rr:objectMap [ rr:column "citizenStatus" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :maritalStatus ;
        rr:objectMap [ rr:column "maritalStatus" ; rr:datatype xsd:string ]
    ] .

# MpR11m — hasInfo association
<#MHasInfo> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TEmployee" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{person_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :hasInfo ;
        rr:objectMap [
            rr:template "http://example.org/enterprise#empinfo/{info_id}"
        ]
    ] .

# ===========================================================================
# MpCE2C — Manager (clustering on role column)
# ===========================================================================

<#MManager> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
        SELECT person_id FROM TEmployee
        WHERE role IN ('manager', 'director')
    """ ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{person_id}" ;
        rr:class :Manager
    ] .

# ===========================================================================
# MpCE2C — Director (clustering on role column)
# ===========================================================================

<#MDirector> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
        SELECT person_id FROM TEmployee
        WHERE role = 'director'
    """ ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{person_id}" ;
        rr:class :Director
    ] .

# ===========================================================================
# MpH — Contractor (PK = FK to Person)
# ===========================================================================

<#MContractor> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TContractor" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{person_id}" ;
        rr:class :Contractor
    ] .

# ===========================================================================
# MpH — Intern (PK = FK to Person)
# ===========================================================================

<#MIntern> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TIntern" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{person_id}" ;
        rr:class :Intern
    ] ;
    rr:predicateObjectMap [
        rr:predicate :allowance ;
        rr:objectMap [ rr:column "allowance" ; rr:datatype xsd:double ]
    ] .

# ===========================================================================
# MpEw — Contract (weak entity: IRI includes parent FK)
# ===========================================================================

<#MContract> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TContract" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#contract/{person_id}/{contract_num}" ;
        rr:class :Contract
    ] ;
    rr:predicateObjectMap [
        rr:predicate :startDate ;
        rr:objectMap [ rr:column "startDate" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :endDate ;
        rr:objectMap [ rr:column "endDate" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :salary ;
        rr:objectMap [ rr:column "salary" ; rr:datatype xsd:double ]
    ] .

# MpEw — hasContract (byproduct of weak entity mapping)
<#MHasContract> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TContract" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{person_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :hasContract ;
        rr:objectMap [
            rr:template "http://example.org/enterprise#contract/{person_id}/{contract_num}"
        ]
    ] .

# ===========================================================================
# MpE — Project
# ===========================================================================

<#MProject> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TProject" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#project/{id}" ;
        rr:class :Project
    ] ;
    rr:predicateObjectMap [
        rr:predicate :projectName ;
        rr:objectMap [ rr:column "projectName" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :budget ;
        rr:objectMap [ rr:column "budget" ; rr:datatype xsd:double ]
    ] .

# ===========================================================================
# MpCE2C — HRProject
# ===========================================================================

<#MHRProject> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
        SELECT id FROM TProject WHERE projectType = 'hr'
    """ ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#project/{id}" ;
        rr:class :HRProject
    ] .

# ===========================================================================
# MpCE2C — BusinessProject
# ===========================================================================

<#MBusinessProject> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
        SELECT id FROM TProject WHERE projectType = 'business'
    """ ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#project/{id}" ;
        rr:class :BusinessProject
    ] .

# ===========================================================================
# MpCE2C — SoftwareProject
# ===========================================================================

<#MSoftwareProject> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
        SELECT id FROM TProject WHERE projectType = 'software'
    """ ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#project/{id}" ;
        rr:class :SoftwareProject
    ] .

# ===========================================================================
# MpE — Department (natural key)
# ===========================================================================

<#MDepartment> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TDepartment" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#department/{dept_code}" ;
        rr:class :Department
    ] ;
    rr:predicateObjectMap [
        rr:predicate :departmentCode ;
        rr:objectMap [ rr:column "dept_code" ; rr:datatype xsd:string ]
    ] .

# ===========================================================================
# MpE — Skill
# ===========================================================================

<#MSkill> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TSkill" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#skill/{id}" ;
        rr:class :Skill
    ] ;
    rr:predicateObjectMap [
        rr:predicate :skillName ;
        rr:objectMap [ rr:column "skillName" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :category ;
        rr:objectMap [ rr:column "category" ; rr:datatype xsd:string ]
    ] .

# ===========================================================================
# MpRR — SkillWithLevel (reified relationship)
# ===========================================================================

<#MSkillWithLevel> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TSkillWithLevel" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#swl/{employee_id}/{skill_id}" ;
        rr:class :SkillWithLevel
    ] ;
    rr:predicateObjectMap [
        rr:predicate :ofEmployee ;
        rr:objectMap [
            rr:template "http://example.org/enterprise#person/{employee_id}"
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :referencesSkill ;
        rr:objectMap [
            rr:template "http://example.org/enterprise#skill/{skill_id}"
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :level ;
        rr:objectMap [ rr:column "level" ; rr:datatype xsd:string ]
    ] .

# ===========================================================================
# MpRa — worksOn (JOIN for identifier alignment)
# Junction table references projectName (UNIQUE), not project PK
# ===========================================================================

<#MWorksOn> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
        SELECT pp.person_id, p.id AS project_id
        FROM TPersonProject pp
        JOIN TProject p ON pp.project_name = p.projectName
    """ ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{person_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :worksOn ;
        rr:objectMap [
            rr:template "http://example.org/enterprise#project/{project_id}"
        ]
    ] .

# ===========================================================================
# MpR — requiresSkill (standard junction table: Project–Skill)
# ===========================================================================

<#MRequiresSkill> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TProjSkill" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#project/{project_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :requiresSkill ;
        rr:objectMap [
            rr:template "http://example.org/enterprise#skill/{skill_id}"
        ]
    ] .

# ===========================================================================
# MpRm — manages (FK merged into TEmployee, self-referencing)
# ===========================================================================

<#MManages> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery """
        SELECT person_id, manager_id FROM TEmployee
        WHERE manager_id IS NOT NULL
    """ ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{manager_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :manages ;
        rr:objectMap [
            rr:template "http://example.org/enterprise#person/{person_id}"
        ]
    ] .

# ===========================================================================
# MpRm — belongsTo (FK merged into TEmployee)
# ===========================================================================

<#MBelongsTo> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TEmployee" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#person/{person_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :belongsTo ;
        rr:objectMap [
            rr:template "http://example.org/enterprise#department/{dept_code}"
        ]
    ] .

# ===========================================================================
# MpRm — hasLeader (FK merged into TDepartment)
# ===========================================================================

<#MHasLeader> a rr:TriplesMap ;
    rr:logicalTable [ rr:tableName "TDepartment" ] ;
    rr:subjectMap [
        rr:template "http://example.org/enterprise#department/{dept_code}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :hasLeader ;
        rr:objectMap [
            rr:template "http://example.org/enterprise#person/{director_id}"
        ]
    ] .
